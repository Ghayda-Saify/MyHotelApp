@page "/admin/hotels"
@using MyHotelApp.Shared.DTOs  @* 👈 PASTE YOUR COPIED NAMESPACE HERE *@
@inject HttpClient Http

<h3>Hotel Management</h3>

@if (hotels == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row mb-3">
        <div class="col">
            <a href="/admin/hotels/create" class="btn btn-primary">
                + Add New Hotel
            </a>
        </div>
    </div>
    <table class="table">
        <thead>
        <tr>
            <th>Name</th>
            <th>Address</th>
            <th>Rating</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var hotel in hotels)
        {
            <tr>
                <td>@hotel.Name</td> @* 👈 Ensure these match the DTO properties *@
                <td>@hotel.Address</td>
                <td>@hotel.StarRating</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private List<HotelDto>? hotels; // 👈 Use the Shared Class Name

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 👇 Ensure this URL matches your API Controller route exactly
            hotels = await Http.GetFromJsonAsync<List<HotelDto>>("api/Hotels");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }
}